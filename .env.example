ASPNETCORE_ENVIRONMENT=Development
DB_CONNECTION=Host=<host>;Port=6543;Database=postgres;Username=<user>;Password=<password>;Ssl Mode=Require;Trust Server Certificate=true;Pooling=false
DB_TIMEOUT_SECONDS=15
CORS_ALLOWED_ORIGINS=https://yourapp.com,http://localhost:3000
API_BASE_URL=http://localhost:5080
# Generate with: openssl rand -base64 48
JWT_SECRET=<generate-a-strong-random-secret-min-32-chars>
STORAGE_BUCKET_NAME=<your-s3-bucket-name>
# AWS credentials for local development — in Lambda these come automatically from the IAM Role.
# AWS_ACCESS_KEY_ID=<your-access-key>
# AWS_SECRET_ACCESS_KEY=<your-secret-key>
# AWS_REGION=sa-east-1

SMTP_HOST=
SMTP_PORT=587 
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=App <naoresponda@yourapp.com>
APP_BASE_URL=https://yourapp.com

# Social Auth (optional)
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=

# Mercado Pago OAuth (Marketplace Connect — PRD-MP-02)
MercadoPago__AccessToken=       # Access Token da conta da plataforma (Credenciais → Produção)
MercadoPago__AppId=             # Application ID numérico (ex: 1234567890) — é o Client ID OAuth
MercadoPago__ClientSecret=      # Client Secret da aplicação MP
MercadoPago__RedirectUri=https://api.<seu-dominio>/payments/mp/callback
MercadoPago__FrontendBaseUrl=https://jobeasy.com.br
