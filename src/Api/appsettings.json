{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  },
  "MercadoPago": {
    "AppId": "",
    "ClientSecret": "",
    "AccessToken": "",
    "IsSandbox": false,
    "WebhookSecret": "",
    "SkipWebhookSignatureValidation": false,
    "RedirectUri": "",
    "FrontendBaseUrl": "",
    "ApiBaseUrl": "",
    "PlatformFeeByTier": {
      "1": 10.0,
      "2": 10.0,
      "3": 8.0,
      "4": 8.0
    },
    "MaxInstallmentsByTier": {
      "1": 6,
      "2": 6,
      "3": 12,
      "4": 12
    },
    "ReleaseDelayDays": 2,
    "ExcludePaymentTypes": [ "ticket" ]
  }
}
