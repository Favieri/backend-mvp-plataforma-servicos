ASPNETCORE_ENVIRONMENT=Development

# ── Banco ──────────────────────────────────────────────────────────────────────
# Supabase Transaction Pooler (porta 6543) para produção/dev compartilhado
DB_CONNECTION=Host=aws-1-sa-east-1.pooler.supabase.com;Port=6543;Database=postgres;Username=postgres.xknwkcunppgsgzvegmgr;Password=jobeasyadmin@1;Ssl Mode=Require;Trust Server Certificate=true;Pooling=false
DB_TIMEOUT_SECONDS=15

# ── Autenticação ───────────────────────────────────────────────────────────────
JWT_SECRET=jobeasy-jwt-secret-dev-2026-change-in-production

# ── CORS ───────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://jobeasy.com.br,http://localhost:3000

# ── App ────────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://jobeasy.com.br
API_BASE_URL=http://localhost:5080

# ── Email ──────────────────────────────────────────────────────────────────────
EMAIL_FROM=Jobeasy <naoresponda@jobeasy.com.br>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Storage ────────────────────────────────────────────────────────────────────
STORAGE_BUCKET_NAME=jobeasy-storage-dev
# Para dev local sem S3: deixe STORAGE_BUCKET_NAME em branco ou configure
